# ============================================
# Fainens - Personal Finance Bookkeeping App
# Environment Variables Configuration
# ============================================

GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Must be the same origin as the browser (Vite dev server) so the session cookie is set on the UI origin.
# Vite proxies /api → backend :3000 (see frontend/vite.config.ts). Register this exact URI in Google Cloud Console.
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# Where OAuth sends the user after login (dashboard). Match your Vite port / production URL.
FRONTEND_URL=http://localhost:8080

# The email address that is allowed to log in (single-user mode)
ALLOWED_EMAIL="rayhanmpramanda@gmail.com"

# --------------------------------------------
# Session Security (Required)
# --------------------------------------------
# Generate a strong random string (64+ characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-this-to-a-random-64-character-secret-key-for-development"

# --------------------------------------------
# Cloudflare R2 Configuration (Optional)
# --------------------------------------------
# Required only if you want attachment upload functionality
# Get these from Cloudflare dashboard: https://dash.cloudflare.com
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=fainens-attachments
# R2_PUBLIC_URL=https://your-bucket.pub-r2.dev

# --------------------------------------------
# Redis (caching — optional; app works without it, slower)
# --------------------------------------------
# Local backend (Redis on your machine):
REDIS_URL=redis://127.0.0.1:6379
# Docker Compose (service name `redis` on the compose network):
# REDIS_URL=redis://redis:6379
# Use this for local development:
# REDIS_URL=redis://localhost:6379

# --------------------------------------------
# App Configuration
# --------------------------------------------
# Set to 'production' for production deployment
NODE_ENV=development

# --------------------------------------------
# OpenRouter API (LLM Insights)
# --------------------------------------------
# Get your API key from: https://openrouter.ai/keys
# This enables AI-powered spending insights and budget analysis
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# --------------------------------------------
# Frontend Configuration (Build time)
# --------------------------------------------
# URL where backend API is hosted
# For Docker: leave as /api (nginx proxies it)
# For local dev: http://localhost:3000
VITE_API_BASE=/api
